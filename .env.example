# Teang Len web — build-time environment.
#
# Vite INLINES these into the JS bundle at build time, so a built image is
# specific to the values it was built with. Copy to .env.local for local dev;
# for deployments pass them as --build-arg (see Makefile / Dockerfile).

# Backend origin. Required for production builds.
VITE_API_URL=http://localhost:4000

# ── Testing environment only ────────────────────────────────────────────────
# true  → a visitor with no session gets a throw-away account generated and
#         registered automatically, landing straight on Home. The credentials
#         are stored in localStorage so refreshes reuse the same account.
# unset/false (PRODUCTION) → normal login/sign-up screen, nothing auto-created.
# An existing signed-in session is never replaced either way.
VITE_AUTO_GUEST=false

# Username prefix for those generated accounts (letters/numbers/underscore).
VITE_AUTO_GUEST_PREFIX=test
