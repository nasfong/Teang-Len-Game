# Teang Len web — build-time environment (COMMITTED defaults).
#
# Vite INLINES these into the JS bundle at build time, so a built image is specific
# to the values it was built with. Precedence, weakest first:
#   .env          this file — shared defaults, in git
#   .env.local    your machine only, gitignored (*.local) — LAN IP, testing flags
#   build args    Dockerfile ARG/ENV, passed by the Makefile — what deploys use
# Vite leaves a variable already present in the environment alone, so a
# --build-arg always wins over what's written here.

# Backend origin. Deployments pass their own; this default keeps `npm run dev`
# working against a local backend with no setup.
VITE_API_URL=http://192.168.21.46:4000

# ── Testing environment only ────────────────────────────────────────────────
# true  → a visitor with no session gets a throw-away account generated and
#         registered automatically, landing straight on Home. The credentials
#         are stored in localStorage so refreshes reuse the same account.
# false (PRODUCTION default) → normal login/sign-up screen, nothing auto-created.
# An existing signed-in session is never replaced either way.
VITE_AUTO_GUEST=true

# Username prefix for those generated accounts (letters/numbers/underscore).
VITE_AUTO_GUEST_PREFIX=test
